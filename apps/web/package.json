{
  "name": "@hoatrinh/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:motd": "bun run scripts/generate-motd.ts",
    "prebuild": "bun run build:motd",
    "predev": "bun run build:motd",
    "preprerender": "bun run build:motd",
    "dev": "vite",
    "build": "vite build",
    "check:contrast": "bun run scripts/check-contrast.ts",
    "preview": "bun run scripts/preview.ts",
    "prerender": "bun run scripts/prerender.ts",
    "local:ai": "bun run build && bun run prerender && bunx wrangler pages dev dist",
    "e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "latest",
    "@fontsource/space-mono": "latest",
    "@hoatrinh/content": "workspace:*",
    "@solidjs/meta": "latest",
    "@solidjs/router": "latest",
    "solid-js": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@solidjs/testing-library": "latest",
    "@testing-library/jest-dom": "latest",
    "@types/bun": "latest",
    "jsdom": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vite-plugin-solid": "latest",
    "vitest": "latest"
  }
}
